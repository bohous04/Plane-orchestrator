# Plane API
# Self-hosted: https://plane.agent42.cz/api/v1
# Plane Cloud: https://api.plane.so/api/v1
PLANE_API_URL=https://plane.agent42.cz/api/v1

# Plane personal token (works across all your workspaces)
# Get from: <PLANE_BASE_URL>/settings/api-tokens
PLANE_TOKEN=plane_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub CLI uses its own auth (gh auth login). Nothing needed here.
# Anthropic / Claude Code uses its own config (claude config). Nothing needed here.
